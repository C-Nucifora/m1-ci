# Pinned M1 toolchain versions — the single source of truth for BOTH the CI
# reusable workflow (.github/workflows/check.yml) and the local pre-commit hooks
# (.pre-commit-hooks.yaml). A consumer that pins this m1-ci tag in both their
# workflow (`uses: …@vX.Y.Z`) and `.pre-commit-config.yaml` (`rev: vX.Y.Z`) gets
# the exact same tools, versions, and flags locally and in CI.
#
# check.yml's input defaults MUST match these — ci.yml enforces it (tools-pins
# job). When the tools release, bump here, bump check.yml's defaults, and cut a
# new m1-ci release.
M1_FMT_VERSION=v0.5.1
M1_LINT_VERSION=v0.9.0
M1_TYPECHECK_VERSION=v0.20.1
